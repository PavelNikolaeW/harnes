# Copy to .env and adjust if needed. docker-compose автоматически читает .env.

# LL-router IP/port. Default — IP в локальной LAN; для другой машины замени.
LLM_API_BASE=http://192.168.0.111:8000/v1
LLM_API_KEY=dummy
LLM_MODEL=gemma-26b-a4b

# Tier-роутинг. В dev все на gemma-26b-a4b; в проде main → gemma-31b-mtp, heavy → qwen-35b.
LLM_TIER_LIGHT=gemma-26b-a4b
LLM_TIER_MAIN=gemma-26b-a4b
LLM_TIER_HEAVY=gemma-26b-a4b

# Verbosity. Для отладки run-loop'а — DEBUG.
LOGGING_LEVEL=INFO
